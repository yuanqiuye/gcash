COMPOSE_PROJECT_NAME=gnucash-user1

# Use 0.0.0.0 to publish on all server interfaces, or a specific LAN IP.
BIND_IP=0.0.0.0
TZ=Asia/Taipei

POSTGRES_USER=gnucash_user1
POSTGRES_PASSWORD=
POSTGRES_DB=gnucash_user1
POSTGRES_HOST_PORT=5432

MCP_HTTP_PORT=8765
GNUCASH_MCP_HTTP_API_KEY=

# Set to 1 for an inspect-only MCP server.
GNUCASH_MCP_READ_ONLY=0

# Set to 1 only for an admin/account-management endpoint.
# The default MCP server does not expose gnucash_create_account, so agents
# cannot create wrong accounts without an explicit operator decision.
GNUCASH_MCP_ALLOW_CREATE_ACCOUNT=0

# Override only when you intentionally need a different published image tag.
GNUCASH_CLI_IMAGE=ghcr.io/yuanqiuye/gcash:master
